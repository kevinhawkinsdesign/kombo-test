DATABASE_URI=file:./payload.db
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used by .mcp.json so Claude Code can call the local Payload MCP server.
# Generate this in the admin panel under MCP -> API Keys, then export it
# in the shell that launches `claude` (Claude Code reads from the shell env,
# not from this .env file).
PAYLOAD_MCP_API_KEY=YOUR_MCP_API_KEY_HERE
